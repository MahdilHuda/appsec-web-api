      "name": "Regression",
      "item": [
        {
          "name": "Create product - rejects invalid name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"returns 400 for whitespace name\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"error response does not leak stack trace\", function () {\r",
                  "  const text = pm.response.text();\r",
                  "  pm.expect(text).to.not.include(\"System.\");\r",
                  "  pm.expect(text).to.not.include(\"at \");\r",
                  "  pm.expect(text).to.not.include(\"Exception\");\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"\",\r\n  \"price\": 12.34\r\n}\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://localhost:7096/products",
              "protocol": "https",
              "host": [
